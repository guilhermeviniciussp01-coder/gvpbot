# ── Frontend (Vite) ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# PagBank — Token de produção (Negócios → Configurações → API e integrações)
VITE_PAGBANK_TOKEN=token_...

# URL pública do SaaS (para redirect após pagamento)
VITE_APP_URL=https://gvpbot.vercel.app

# ── Backend / Serverless Functions (sem prefixo VITE_) ────────────
# Supabase service_role key — usada APENAS no webhook (nunca expor no frontend)
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  ← service_role key (Project Settings → API)

# PagBank token para validar pagamentos no webhook (server-side)
PAGBANK_TOKEN=token_...
